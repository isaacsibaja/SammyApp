<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools" >

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/ic_sammy_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_sammy_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.SammyApp" >
        
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.App.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ColorsActivity"
            android:exported="false"
            android:label="Learn Colors" />
        
        <activity
            android:name=".AnimalsActivity"
            android:exported="false"
            android:label="Learn Animals" />
        
        <activity
            android:name=".AlphabetActivity"
            android:exported="false"
            android:label="Learn Alphabet" />

        <activity
            android:name=".NumbersActivity"
            android:exported="false"
            android:label="Learn Numbers" />

        <activity
            android:name=".FruitsActivity"
            android:exported="false"
            android:label="Learn Fruits" />

        <activity
            android:name=".ObjectsActivity"
            android:exported="false"
            android:label="Learn Objects" />

    </application>

</manifest>