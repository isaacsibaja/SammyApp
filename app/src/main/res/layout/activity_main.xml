<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_soft"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <androidx.cardview.widget.CardView
            android:layout_width="120dp"
            android:layout_height="120dp"
            app:cardCornerRadius="60dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">
            
            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/mi_logo"
                android:scaleType="centerCrop"
                android:contentDescription="App Logo" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:fontFamily="sans-serif-medium"
            android:text="Categories"
            android:gravity="center"
            android:textColor="@color/colorPrimaryDark"
            android:textSize="42sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnColors"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:padding="20dp"
            android:text="Colors"
            android:textSize="20sp"
            android:textAllCaps="false"
            app:cornerRadius="20dp"
            android:backgroundTint="@color/pastel_pink"
            android:textColor="@color/text_dark"
            app:icon="@android:drawable/ic_menu_gallery"
            app:iconGravity="textStart"
            app:iconTint="@color/text_dark" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAnimals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:padding="20dp"
            android:text="Animals"
            android:textSize="20sp"
            android:textAllCaps="false"
            app:cornerRadius="20dp"
            android:backgroundTint="@color/pastel_green"
            android:textColor="@color/text_dark"
            app:icon="@android:drawable/ic_menu_view"
            app:iconGravity="textStart"
            app:iconTint="@color/text_dark" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAlphabet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:padding="20dp"
            android:text="Alphabet"
            android:textSize="20sp"
            android:textAllCaps="false"
            app:cornerRadius="20dp"
            android:backgroundTint="@color/pastel_blue"
            android:textColor="@color/text_dark"
            app:icon="@android:drawable/ic_menu_sort_alphabetically"
            app:iconGravity="textStart"
            app:iconTint="@color/text_dark" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNumbers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:padding="20dp"
            android:text="Numbers"
            android:textSize="20sp"
            android:textAllCaps="false"
            app:cornerRadius="20dp"
            android:backgroundTint="@color/pastel_yellow"
            android:textColor="@color/text_dark"
            app:icon="@android:drawable/ic_menu_today"
            app:iconGravity="textStart"
            app:iconTint="@color/text_dark" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFruits"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:padding="20dp"
            android:text="Fruits"
            android:textSize="20sp"
            android:textAllCaps="false"
            app:cornerRadius="20dp"
            android:backgroundTint="@color/pastel_orange"
            android:textColor="@color/text_dark"
            app:icon="@android:drawable/ic_menu_camera"
            app:iconGravity="textStart"
            app:iconTint="@color/text_dark" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnObjects"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:padding="20dp"
            android:text="Objects"
            android:textSize="20sp"
            android:textAllCaps="false"
            app:cornerRadius="20dp"
            android:backgroundTint="@color/pastel_purple"
            android:textColor="@color/text_dark"
            app:icon="@android:drawable/ic_menu_manage"
            app:iconGravity="textStart"
            app:iconTint="@color/text_dark" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDays"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:padding="20dp"
            android:text="Days"
            android:textSize="20sp"
            android:textAllCaps="false"
            app:cornerRadius="20dp"
            android:backgroundTint="#B2DFDB"
            android:textColor="@color/text_dark"
            app:icon="@android:drawable/ic_menu_my_calendar"
            app:iconGravity="textStart"
            app:iconTint="@color/text_dark" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMonths"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:padding="20dp"
            android:text="Months"
            android:textSize="20sp"
            android:textAllCaps="false"
            app:cornerRadius="20dp"
            android:backgroundTint="#A2D2FF"
            android:textColor="@color/text_dark"
            app:icon="@android:drawable/ic_menu_month"
            app:iconGravity="textStart"
            app:iconTint="@color/text_dark" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnProfessions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:padding="20dp"
            android:text="Professions"
            android:textSize="20sp"
            android:textAllCaps="false"
            app:cornerRadius="20dp"
            android:backgroundTint="#FFCCAC"
            android:textColor="@color/text_dark"
            app:icon="@android:drawable/ic_menu_edit"
            app:iconGravity="textStart"
            app:iconTint="@color/text_dark" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:padding="20dp"
            android:text="Math"
            android:textSize="20sp"
            android:textAllCaps="false"
            app:cornerRadius="20dp"
            android:backgroundTint="#B2F2BB"
            android:textColor="@color/text_dark"
            app:icon="@android:drawable/ic_menu_add"
            app:iconGravity="textStart"
            app:iconTint="@color/text_dark" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBodyParts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:padding="20dp"
            android:text="Body Parts"
            android:textSize="20sp"
            android:textAllCaps="false"
            app:cornerRadius="20dp"
            android:backgroundTint="#F8BBD0"
            android:textColor="@color/text_dark"
            app:icon="@android:drawable/ic_menu_info_details"
            app:iconGravity="textStart"
            app:iconTint="@color/text_dark" />

    </LinearLayout>
</ScrollView>